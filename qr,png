<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lecturas Psíquicas</title>

<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Raleway&display=swap" rel="stylesheet">

<style>
body {
    margin: 0;
    font-family: 'Raleway', sans-serif;
    color: white;
    background: radial-gradient(circle at top, #1a1a2e, #0f0c29);
    overflow-x: hidden;
}

/* Fondo estrellas */
body::before {
    content: "";
    position: fixed;
    width: 100%;
    height: 100%;
    background: url('https://www.transparenttextures.com/patterns/stardust.png');
    opacity: 0.25;
    z-index: -1;
}

/* HERO */
.hero {
    text-align: center;
    padding: 100px 20px;
}

.hero h1 {
    font-family: 'Cinzel', serif;
    font-size: 3em;
    letter-spacing: 3px;
}

.hero p {
    max-width: 600px;
    margin: auto;
    font-size: 1.2em;
}

/* QR */
.qr img {
    width: 200px;
    margin-top: 20px;
    border-radius: 15px;
    box-shadow: 0 0 25px rgba(255,255,255,0.4);
}

/* SECCIONES */
.section {
    padding: 60px 20px;
    text-align: center;
}

h2 {
    font-family: 'Cinzel', serif;
}

/* FORMULARIO */
form {
    max-width: 500px;
    margin: auto;
}

input, textarea, select {
    width: 100%;
    padding: 12px;
    margin: 10px 0;
    border: none;
    border-radius: 10px;
}

button {
    padding: 12px;
    border: none;
    border-radius: 20px;
    background: linear-gradient(45deg, #6a11cb, #2575fc);
    color: white;
    cursor: pointer;
    width: 100%;
}

button:hover {
    opacity: 0.8;
}

footer {
    text-align: center;
    padding: 20px;
    opacity: 0.6;
}
</style>

</head>
<body>

<!-- HERO -->
<div class="hero">
    <h1>Lecturas Psíquicas</h1>
    <p>Descubre los mensajes ocultos del universo y conecta con tu destino.</p>

    <div class="qr">
        <p>Escanea para hablar con el bot</p>
        <img src="qr.png" alt="QR del bot">
    </div>
</div>

<!-- SERVICIO -->
<div class="section">
    <h2>¿Qué es una lectura psíquica?</h2>
    <p>
        Es un espacio de conexión espiritual donde se interpretan energías,
        emociones y caminos posibles para tu vida. Recibe guía en el amor,
        decisiones y crecimiento personal.
    </p>
</div>

<!-- FORMULARIO -->
<div class="section">
    <h2>Reserva tu sesión</h2>

    <form onsubmit="enviarWhatsApp(event)">
        <input type="text" id="nombre" placeholder="Nombre" required>
        <input type="email" id="correo" placeholder="Correo electrónico" required>

        <select id="tipo" required>
            <option value="">Tipo de consulta</option>
            <option>Amor</option>
            <option>Trabajo</option>
            <option>Espiritual</option>
        </select>

        <textarea id="mensaje" placeholder="Cuéntame tu situación"></textarea>

        <button type="submit">Reservar por WhatsApp</button>
    </form>
</div>

<footer>
    © 2026 Lecturas Psíquicas
</footer>

<script>
function enviarWhatsApp(event) {
    event.preventDefault();

    let nombre = document.getElementById("nombre").value;
    let correo = document.getElementById("correo").value;
    let tipo = document.getElementById("tipo").value;
    let mensaje = document.getElementById("mensaje").value;

    let texto = `Hola, quiero reservar una lectura psíquica:%0A
Nombre: ${nombre}%0A
Correo: ${correo}%0A
Tipo: ${tipo}%0A
Mensaje: ${mensaje}`;

    let numero = "573000000000"; // 👈 CAMBIA POR TU NÚMERO

    window.open(`https://wa.me/${numero}?text=${texto}`, "_blank");
}
</script>

</body>
</html>
